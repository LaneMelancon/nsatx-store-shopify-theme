{
  "sections": {
    "component-library": {
      "type": "component-library",
      "blocks": {
        "cl-product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "product_card_gap": 12,
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 10,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "cl-gallery": {
              "type": "_product-card-gallery",
              "settings": {
                "image_ratio": "portrait",
                "border": "none",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 10
              }
            },
            "cl-title": {
              "type": "product-title",
              "settings": {
                "type_preset": "paragraph",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "padding-block-start": 8,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              }
            },
            "cl-price": {
              "type": "price",
              "settings": {
                "show_sale_price_first": true,
                "padding-block-start": 4,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              }
            }
          },
          "block_order": ["cl-gallery", "cl-title", "cl-price"]
        },
        "cl-collection-card": {
          "type": "_collection-card",
          "static": true,
          "settings": {
            "placement": "on_image",
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "flex-end",
            "collection_card_gap": 8,
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 10
          },
          "blocks": {
            "cl-collection-title": {
              "type": "collection-title",
              "settings": {
                "type_preset": "h5",
                "font": "var(--font-body--family)",
                "font_size": "1.125rem",
                "alignment": "left",
                "case": "none",
                "wrap": "pretty",
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              }
            },
            "collection-card-image": {
              "type": "_collection-card-image",
              "static": true,
              "settings": {
                "image_ratio": "portrait",
                "toggle_overlay": true,
                "overlay_color": "#00000033",
                "overlay_style": "gradient",
                "gradient_direction": "to top",
                "border": "none",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 0
              }
            }
          },
          "block_order": ["cl-collection-title"]
        }
      },
      "block_order": [],
      "settings": {}
    }
  },
  "order": ["component-library"]
}
