  {%- comment -%} 07 — ACCORDION {%- endcomment -%}
  {%- comment -%} ─────────────────────────────────────────────────────────── {%- endcomment -%}
  <section id="cl-accordion" class="cl-section">
    <p class="cl-eyebrow">07</p>
    <h2 class="h2 cl-section-title">Accordion</h2>

    <div class="cl-two-col">
      <div class="cl-item cl-item--fill">
        <p class="cl-label">&lt;accordion-custom&gt; with .icon-plus</p>
        <div class="cl-demo">
          <accordion-custom>
            <details class="details">
              <summary>
                <span>What ingredients are in this supplement?</span>
                <span class="svg-wrapper">
                  <span class="icon-plus">
                    <svg class="horizontal" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    <svg class="vertical" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/></svg>
                  </span>
                </span>
              </summary>
              <div class="details-content">
                <div class="rte">
                  <p>Contains a proprietary blend of adaptogens, vitamins, and minerals formulated for cognitive performance. Full ingredient list on the product label.</p>
                </div>
              </div>
            </details>
          </accordion-custom>
          <accordion-custom>
            <details class="details">
              <summary>
                <span>How should I take this product?</span>
                <span class="svg-wrapper">
                  <span class="icon-plus">
                    <svg class="horizontal" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    <svg class="vertical" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/></svg>
                  </span>
                </span>
              </summary>
              <div class="details-content">
                <div class="rte">
                  <p>Take two capsules daily with water, preferably with a meal. Do not exceed the recommended daily dose. Consult your healthcare provider before use.</p>
                </div>
              </div>
            </details>
          </accordion-custom>
          <accordion-custom>
            <details class="details" open>
              <summary>
                <span>Is this product third-party tested?</span>
                <span class="svg-wrapper">
                  <span class="icon-plus">
                    <svg class="horizontal" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    <svg class="vertical" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/></svg>
                  </span>
                </span>
              </summary>
              <div class="details-content">
                <div class="rte">
                  <p>Yes. All products are independently tested for purity and potency. Certificates of Analysis are available on request. (This item is open by default via the <code>open</code> attribute.)</p>
                </div>
              </div>
            </details>
          </accordion-custom>
        </div>
      </div>

      <div class="cl-item cl-item--fill">
        <p class="cl-label">&lt;accordion-custom&gt; with .icon-caret</p>
        <div class="cl-demo">
          <accordion-custom>
            <details class="details">
              <summary>
                <span>Shipping &amp; Returns</span>
                <span class="svg-wrapper">
                  <svg class="icon-caret" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <div class="details-content">
                <div class="rte">
                  <p>Orders ship within 1–2 business days. Standard delivery 5–7 business days. Free shipping on orders over $75. Returns accepted within 30 days of purchase.</p>
                </div>
              </div>
            </details>
          </accordion-custom>
          <accordion-custom data-disable-on-mobile="true">
            <details class="details">
              <summary>
                <span>Disabled on Mobile (data-disable-on-mobile)</span>
                <span class="svg-wrapper">
                  <svg class="icon-caret" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <div class="details-content">
                <div class="rte">
                  <p>This accordion is always open on mobile because <code>data-disable-on-mobile="true"</code> is set. On desktop it collapses normally.</p>
                </div>
              </div>
            </details>
          </accordion-custom>
          <accordion-custom data-close-with-escape="true">
            <details class="details">
              <summary>
                <span>Closes with Escape Key</span>
                <span class="svg-wrapper">
                  <svg class="icon-caret" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <div class="details-content">
                <div class="rte">
                  <p>This accordion respects <kbd>Escape</kbd> to close because <code>data-close-with-escape="true"</code> is set.</p>
                </div>
              </div>
            </details>
          </accordion-custom>
        </div>
      </div>
    </div>
  </section>


