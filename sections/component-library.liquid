  <section id="cl-web-components" class="cl-section">
    <p class="cl-eyebrow">14</p>
    <h2 class="h2 cl-section-title">Web Components</h2>
    <p class="paragraph" style="margin-block-end: var(--margin-4xl);">All custom elements registered via <code>customElements.define()</code> in the Tinker theme. Each component follows the Shopify Dawn pattern — vanilla JS, no framework.</p>

    <table class="cl-wc-table">
      <thead>
        <tr>
          <th>Element</th>
          <th>Source File</th>
          <th>Key Attributes / Refs</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>&lt;product-card&gt;</td>
          <td>product-card.js</td>
          <td>data-product-transition, data-featured-media-url, data-no-navigation — ref: productCardLink (required), slideshow, quickAdd, cardGallery</td>
        </tr>
        <tr>
          <td>&lt;quick-add-component&gt;</td>
          <td>quick-add.js</td>
          <td>data-product-title, data-product-options-count — opens &lt;quick-add-dialog&gt; modal</td>
        </tr>
        <tr>
          <td>&lt;quick-add-dialog&gt;</td>
          <td>quick-add.js</td>
          <td>Modal dialog — child: #quick-add-modal-content[data-product-grid-content]</td>
        </tr>
        <tr>
          <td>&lt;slideshow-component&gt;</td>
          <td>slideshow.js</td>
          <td>autoplay="{s}", infinite, initial-slide, mobile-disabled, auto-hide-controls — ref: scroller (req), slideshowContainer (req), slides, previous, next, dots, thumbnails</td>
        </tr>
        <tr>
          <td>&lt;slideshow-slide&gt;</td>
          <td>slideshow.js</td>
          <td>ref="slides", slide-id, aria-hidden, variant-image — child of &lt;slideshow-component&gt;</td>
        </tr>
        <tr>
          <td>&lt;accordion-custom&gt;</td>
          <td>accordion-custom.js</td>
          <td>data-disable-on-mobile, data-disable-on-desktop, data-close-with-escape, open-by-default-on-mobile, open-by-default-on-desktop — requires child &lt;details&gt;&lt;summary&gt;</td>
        </tr>
        <tr>
          <td>&lt;marquee-component&gt;</td>
          <td>marquee.js</td>
          <td>data-speed-factor (required) — ref: wrapper (req), content (req), marqueeItems (multiple, req)</td>
        </tr>
        <tr>
          <td>&lt;jumbo-text&gt;</td>
          <td>jumbo-text.js</td>
          <td>data-text-effect, data-animation-repeat, data-cap-text — scales font-size to fill container width</td>
        </tr>
        <tr>
          <td>&lt;quantity-selector-component&gt;</td>
          <td>component-quantity-selector.js</td>
          <td>ref: quantityInput (req), minusButton (req), plusButton (req) — emits QuantitySelectorUpdateEvent</td>
        </tr>
        <tr>
          <td>&lt;product-price&gt;</td>
          <td>(inline web component)</td>
          <td>Manages .price__regular / .price__sale / .price__hidden visibility — children: .tax-note, .volume-pricing-note</td>
        </tr>
        <tr>
          <td>&lt;media-gallery&gt;</td>
          <td>(inline web component)</td>
          <td>Gallery grid controller — children: .media-gallery__grid, .product-media-container — uses --gallery-aspect-ratio, --image-gap</td>
        </tr>
        <tr>
          <td>&lt;deferred-media&gt;</td>
          <td>(inline web component)</td>
          <td>Lazy-loads video/iframe on interaction — states: [data-media-loaded] — children: .deferred-media__poster-button, template</td>
        </tr>
        <tr>
          <td>&lt;product-model&gt;</td>
          <td>(inline web component)</td>
          <td>Wraps Shopify model-viewer — children: model-viewer, .deferred-media__poster-button</td>
        </tr>
        <tr>
          <td>&lt;fly-to-cart&gt;</td>
          <td>(inline web component)</td>
          <td>Animated product-to-cart fly animation — modifiers: --main, --quick, --sticky — uses --offset-y, --width, --start-x/y, --travel-x/y</td>
        </tr>
      </tbody>
    </table>
  </section>


</div>

