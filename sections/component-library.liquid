  {%- comment -%} 04 — QUANTITY SELECTOR {%- endcomment -%}
  {%- comment -%} ─────────────────────────────────────────────────────────── {%- endcomment -%}
  <section id="cl-quantity" class="cl-section">
    <p class="cl-eyebrow">04</p>
    <h2 class="h2 cl-section-title">Quantity Selector</h2>

    <div class="cl-row cl-row--center">
      <div class="cl-item">
        <p class="cl-label">Default &lt;quantity-selector-component&gt;</p>
        <quantity-selector-component>
          <div class="quantity-selector">
            <button class="quantity-minus" ref="minusButton" type="button" aria-label="Decrease quantity">
              <span class="svg-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </button>
            <input ref="quantityInput" type="number" min="1" max="99" step="1" value="1" data-cart-quantity="0" aria-label="Quantity" id="cl-qty-1" name="quantity">
            <button class="quantity-plus" ref="plusButton" type="button" aria-label="Increase quantity">
              <span class="svg-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </button>
          </div>
        </quantity-selector-component>
      </div>

      <div class="cl-item">
        <p class="cl-label">At minimum — minus disabled</p>
        <quantity-selector-component>
          <div class="quantity-selector">
            <button class="quantity-minus" ref="minusButton" type="button" aria-label="Decrease quantity" disabled>
              <span class="svg-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </button>
            <input ref="quantityInput" type="number" min="1" max="99" step="1" value="1" data-cart-quantity="0" aria-label="Quantity" id="cl-qty-2" name="quantity">
            <button class="quantity-plus" ref="plusButton" type="button" aria-label="Increase quantity">
              <span class="svg-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </button>
          </div>
        </quantity-selector-component>
      </div>
    </div>
