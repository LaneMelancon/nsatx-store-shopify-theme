  <section id="cl-utilities" class="cl-section">
    <p class="cl-eyebrow">13</p>
    <h2 class="h2 cl-section-title">Utility Classes</h2>

    <div class="cl-two-col">
      <div>
        <h3 class="h5" style="margin-block-end: var(--margin-md);">Display &amp; Visibility</h3>
        <div class="cl-demo" style="margin-block-end: var(--margin-4xl);">
          <div style="display: flex; flex-direction: column; gap: var(--gap-xs); font-size: var(--font-size--sm); font-family: var(--font-body--family);">
            <code>.hidden — display: none !important</code>
            <code>.hidden--mobile — hidden at max-width 749px</code>
            <code>.hidden--desktop — hidden at min-width 750px</code>
            <code>.visually-hidden — visible to screen readers only</code>
            <code>.is-visually-hidden-mobile — screen-reader only on mobile</code>
            <code>.hide-when-empty — hidden when :empty</code>
            <code>.contents — display: contents</code>
            <code>.relative — position: relative</code>
          </div>
        </div>

        <h3 class="h5" style="margin-block-end: var(--margin-md);">Background Images</h3>
        <div class="cl-demo">
          <div style="display: flex; flex-direction: column; gap: var(--gap-xs); font-size: var(--font-size--sm); font-family: var(--font-body--family);">
            <code>.background-image-container — absolute fill, object-fit: cover</code>
            <code>.background-image-fit — object-fit: contain</code>
            <code>.container-background-image — bg-size: cover, no-repeat</code>
          </div>
        </div>
      </div>

      <div>
        <h3 class="h5" style="margin-block-end: var(--margin-md);">Transition Helpers</h3>
        <div class="cl-demo" style="margin-block-end: var(--margin-4xl);">
          <div style="display: flex; flex-direction: column; gap: var(--gap-xs); font-size: var(--font-size--sm); font-family: var(--font-body--family);">
            <code>.transition-background-color — speed-medium ease-in-out</code>
            <code>.transition-transform — speed-medium timing-bounce</code>
            <code>.transition-border-color — speed-medium timing-hover</code>
          </div>
        </div>

        <h3 class="h5" style="margin-block-end: var(--margin-md);">Spacing System Classes</h3>
        <div class="cl-demo">
          <div style="display: flex; flex-direction: column; gap: var(--gap-xs); font-size: var(--font-size--sm); font-family: var(--font-body--family);">
            <code>.spacing-style — reads --padding-block-* and --margin-block-* vars</code>
            <code>.inherit-spacing — inherits spacing from parent .spacing-style</code>
            <code>.gap-style — sets gap from --gap var (scales with --gap-scale)</code>
            <code>.size-style — reads --size-style-width / --size-style-height vars</code>
            <code>.border-style — reads --border-width / --border-color / --border-radius</code>
          </div>
        </div>
      </div>
