{%- comment -%}
  sections/component-library.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Tinker Theme — Native Component Library
  All components use Tinker's exact HTML patterns, CSS classes, and web
  components. No design system overrides. Placeholder copy is dummy content
  only and does not affect the live theme.
{%- endcomment -%}

{% stylesheet %}

/* ── Component Library Shell ─────────────────────────────────────────────── */

.cl-page {
  padding-block: var(--padding-5xl);
}

.cl-page-header {
  padding-block-end: var(--padding-4xl);
  border-bottom: var(--style-border-width) solid rgb(var(--color-border-rgb) / var(--opacity-50));
  margin-block-end: var(--margin-4xl);
}

.cl-page-header h1 {
  margin-block: var(--margin-xs) 0;
}

.cl-nav {
  position: sticky;
  top: 0;
  z-index: var(--layer-sticky);
  background-color: var(--color-background);
  border-bottom: var(--style-border-width) solid rgb(var(--color-border-rgb) / var(--opacity-50));
  padding-block: var(--padding-xs);
  margin-block-end: var(--margin-4xl);
  overflow-x: auto;
  scrollbar-width: none;
}

.cl-nav::-webkit-scrollbar { display: none; }

.cl-nav__list {
  display: flex;
  gap: var(--gap-2xs);
  list-style: none;
  margin: 0;
  padding: 0;
  white-space: nowrap;
}

.cl-nav__link {
  display: inline-block;
  padding: var(--padding-2xs) var(--padding-sm);
  font-size: var(--font-size--xs);
  font-family: var(--font-body--family);
  color: var(--color-foreground);
  text-decoration: none;
  border-radius: var(--style-border-radius-xs);
  transition: background-color var(--animation-values);
  opacity: var(--opacity-70);
}

.cl-nav__link:hover {
  background-color: rgb(var(--color-foreground-rgb) / var(--opacity-8));
  opacity: 1;
}

.cl-section {
  padding-block: var(--padding-4xl);
  border-bottom: var(--style-border-width) solid rgb(var(--color-border-rgb) / var(--opacity-50));
}

.cl-section:last-child {
  border-bottom: none;
}

.cl-eyebrow {
  font-size: var(--font-size--2xs);
  font-family: var(--font-body--family);
  font-weight: 600;
  letter-spacing: var(--letter-spacing-md);
  text-transform: uppercase;
  color: rgb(var(--color-foreground-rgb) / var(--opacity-40));
  margin-block-end: var(--margin-2xs);
}

.cl-section-title {
  margin-block-end: var(--margin-4xl);
}

.cl-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--gap-2xl);
  align-items: flex-start;
  margin-block-end: var(--margin-4xl);
}

.cl-row:last-child { margin-block-end: 0; }

.cl-row--center { align-items: center; }
.cl-row--col { flex-direction: column; }

.cl-item {
  display: flex;
  flex-direction: column;
  gap: var(--gap-xs);
  min-width: 0;
}

.cl-item--fill {
  flex: 1;
  min-width: min(280px, 100%);
}

.cl-label {
  font-size: var(--font-size--2xs);
  font-family: var(--font-body--family);
  color: rgb(var(--color-foreground-rgb) / var(--opacity-60));
  font-weight: 500;
  letter-spacing: 0.02em;
}

.cl-demo {
  padding: var(--padding-lg);
  background-color: rgb(var(--color-foreground-rgb) / var(--opacity-5));
  border-radius: var(--style-border-radius-sm);
  border: var(--style-border-width) solid rgb(var(--color-border-rgb) / var(--opacity-50));
}

.cl-demo--lg {
  padding: var(--padding-4xl);
}

.cl-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--gap-3xl);
}

@media (max-width: 749px) {
  .cl-two-col { grid-template-columns: 1fr; }
}

.cl-icon-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
  gap: var(--gap-xs);
}

.cl-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--gap-2xs);
  padding: var(--padding-sm) var(--padding-xs);
  border-radius: var(--style-border-radius-xs);
  background-color: rgb(var(--color-foreground-rgb) / var(--opacity-5));
  text-align: center;
}

.cl-icon-item .cl-icon-name {
  font-size: 9px;
  font-family: var(--font-body--family);
  color: rgb(var(--color-foreground-rgb) / var(--opacity-60));
  word-break: break-all;
  line-height: 1.3;
}

.cl-wc-table {
  width: 100%;
  border-collapse: collapse;
}

.cl-wc-table th,
.cl-wc-table td {
  padding: var(--padding-sm) var(--padding-md);
  text-align: left;
  font-size: var(--font-size--sm);
  font-family: var(--font-body--family);
  border-bottom: var(--style-border-width) solid rgb(var(--color-border-rgb) / var(--opacity-50));
}

.cl-wc-table th {
  font-weight: 600;
  font-size: var(--font-size--2xs);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: rgb(var(--color-foreground-rgb) / var(--opacity-60));
  background-color: rgb(var(--color-foreground-rgb) / var(--opacity-5));
}

.cl-wc-table td:first-child {
  font-family: monospace;
  font-size: var(--font-size--xs);
  color: var(--color-foreground);
}

.cl-wc-table td:not(:first-child) {
  color: rgb(var(--color-foreground-rgb) / var(--opacity-70));
  font-size: var(--font-size--xs);
}

/* ── Snippet Stylesheets ─────────────────────────────────────────────────────
   CSS from snippet {% stylesheet %} blocks. Copied here because these snippets
   are not rendered via {% render %} — their stylesheet blocks would not load.
   ─────────────────────────────────────────────────────────────────────────── */

/* pagination-controls.liquid */
.pagination {
  --pagination-size: 36px;
  --pagination-inset: 2px;
  --pagination-radius: 6;

  display: flex;
  justify-content: center;
  padding: var(--padding-xl) var(--padding-sm);
  margin-top: var(--padding-xl);
  position: relative;
  isolation: isolate;
}

.pagination__list {
  display: flex;
  gap: 0;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  position: relative;
}

.pagination__item {
  width: var(--pagination-size);
  aspect-ratio: 1;
  display: grid;
  place-items: center;
}

.pagination__link {
  display: grid;
  place-items: center;
  color: var(--color-foreground);
  text-decoration: none;
  width: 100%;
  height: 100%;
  user-select: none;
  position: relative;
  outline-color: var(--color-foreground);
  -webkit-tap-highlight-color: transparent;
  font-size: var(--font-size--md);
  font-weight: var(--font-weight-normal);
  border-radius: calc(var(--pagination-radius) * 1px);
  transition: color var(--hover-transition-duration) var(--hover-transition-timing),
    opacity var(--hover-transition-duration) var(--hover-transition-timing);
}

.pagination__link:focus-visible {
  outline: 2px solid var(--color-foreground);
  outline-offset: 2px;
}

.pagination__link--current {
  color: var(--color-background);
  font-weight: var(--font-weight-medium);
  cursor: default;
}

.pagination__link--gap {
  cursor: default;
  pointer-events: none;
}

.pagination__link--arrow {
  display: flex;
  align-items: center;
  justify-content: center;
}

.pagination__link--disabled {
  opacity: 0.3;
  cursor: not-allowed;
  pointer-events: none;
}

.pagination__link svg {
  width: 0.5rem;
  height: 0.75rem;
  flex-shrink: 0;
}

.pagination__link--current::before {
  content: '';
  position: absolute;
  inset: var(--pagination-inset);
  border-radius: calc(var(--pagination-radius) * 1px);
  background: var(--color-foreground);
  z-index: -1;
}

.pagination__link:not(.pagination__link--gap, .pagination__link--disabled, .pagination__link--current):hover::before {
  content: '';
  position: absolute;
  inset: var(--pagination-inset);
  border-radius: calc(var(--pagination-radius) * 1px);
  background: rgb(var(--color-foreground-rgb) / var(--opacity-10));
  z-index: -1;
}

@media screen and (max-width: 749px) {
  .pagination {
    --pagination-size: 44px;
    --pagination-inset: 5px;
    padding: var(--padding-lg) var(--padding-sm);
  }

  .pagination__link {
    font-size: var(--font-size--sm);
  }

  .pagination__item--mobile-hide {
    display: none;
  }
}

/* divider.liquid */
.divider {
  align-self: stretch;
  display: flex;
  align-items: center;
  justify-content: var(--divider-justify-content);
}

.divider__line {
  border-bottom: var(--divider-border-thickness) solid var(--color-border);
  border-right: var(--divider-border-thickness) solid var(--color-border);
  border-radius: calc(var(--style-border-radius-sm) * var(--divider-border-rounded));
  flex-basis: var(--divider-flex-basis);
  min-height: var(--divider-flex-basis);
}

/* cart-bubble.liquid */
.cart-bubble {
  --cart-padding: 0.2em;

  position: relative;
  width: 20px;
  aspect-ratio: 1;
  border-radius: 50%;
  border-width: 0;
  display: flex;
  line-height: normal;
  align-items: center;
  justify-content: center;
  color: var(--cart-bubble-text, var(--cart-bubble-text-fallback));
  padding-inline: var(--cart-padding);
}

.cart-bubble[data-maintain-ratio] {
  aspect-ratio: 1;
}

.cart-bubble[data-maintain-ratio] .cart-bubble__background {
  border-radius: var(--style-border-radius-50);
}

.cart-bubble__background {
  position: absolute;
  inset: 0;
  background-color: var(--cart-bubble-background, var(--cart-bubble-background-fallback));
  border-radius: var(--style-border-radius-lg);
}

.cart-bubble__text {
  font-size: var(--font-size--3xs);
  z-index: var(--layer-flat);
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* bento-grid.liquid */
.bento-box {
  display: grid;
  column-gap: var(--bento-gap);
  row-gap: calc(var(--bento-gap) * 1.5);
  width: 100%;
}

@media screen and (max-width: 900px) {
  .bento-box {
    grid-template-columns: repeat(2, 1fr);
  }

  .bento-box__item { min-width: 0; overflow: hidden; }
  .bento-box__item:nth-child(3n + 1) { grid-column: span 1; }
  .bento-box__item:nth-child(3n + 2) { grid-column: span 1; }
  .bento-box__item:nth-child(3n + 3) { grid-column: span 2; }
}

@media screen and (min-width: 901px) {
  .bento-box {
    grid-template-columns: repeat(12, 1fr);
    grid-template-areas:
      'A A A B B B B B B C C C'
      'D D D D D D E E E F F F'
      'G G G H H H I I I I I I'
      'J J J J K K K K L L L L';
  }

  .bento-box__item:nth-child(1) { grid-area: A; }
  .bento-box__item:nth-child(2) { grid-area: B; }
  .bento-box__item:nth-child(3) { grid-area: C; }
  .bento-box__item:nth-child(4) { grid-area: D; }
  .bento-box__item:nth-child(5) { grid-area: E; }
  .bento-box__item:nth-child(6) { grid-area: F; }

  .bento-box--items-1 { grid-template-areas: 'A A A A A A A A A A A A'; }
  .bento-box--items-2 { grid-template-areas: 'A A A A A A B B B B B B'; }
  .bento-box--items-4 {
    grid-template-areas:
      'A A A A B B B B B B B B'
      'C C C C C C C C D D D D';
  }
  .bento-box--items-5 {
    grid-template-areas:
      'A A A B B B B B B C C C'
      'D D D D D D E E E E E E';
  }
}

/* overlay.liquid */
.overlay {
  position: absolute;
  inset: 0;
  z-index: var(--overlay-layer);
  pointer-events: none;
  border-radius: var(--overlay-border-radius, 0);
}

.overlay--solid {
  background: var(--overlay-color);
}

.overlay--gradient {
  background: linear-gradient(var(--overlay-direction), var(--overlay-color), var(--overlay-color--end));
}

/* accordion-custom-component.liquid (de-nested) */
accordion-custom details::details-content,
accordion-custom details .details-content {
  block-size: 0;
  overflow-y: clip;
  opacity: 0;
  interpolate-size: allow-keywords;
  transition:
    content-visibility var(--animation-speed-slow) allow-discrete,
    padding-block var(--animation-speed-slow) var(--animation-easing),
    opacity var(--animation-speed-slow) var(--animation-easing),
    block-size var(--animation-speed-slow) var(--animation-easing);
}

accordion-custom details:not(:focus-within)::details-content,
accordion-custom details:not(:focus-within) .details-content {
  transition: none;
}

accordion-custom details:not([open])::details-content,
accordion-custom details:not([open]) .details-content {
  padding-block: 0;
}

accordion-custom details[open]::details-content,
accordion-custom details[open] .details-content {
  opacity: 1;
  block-size: auto;
}

accordion-custom details[open] .details-content:focus-within {
  overflow-y: visible;
}

@starting-style {
  accordion-custom details[open]::details-content,
  accordion-custom details[open] .details-content {
    block-size: 0;
    opacity: 0;
    overflow-y: clip;
  }
}

@media screen and (max-width: 749px) {
  accordion-custom[data-disable-on-mobile='true'] summary {
    cursor: auto;
  }
}

@media screen and (min-width: 750px) {
  accordion-custom[data-disable-on-desktop='true'] summary {
    cursor: auto;
  }
}

{% endstylesheet %}


