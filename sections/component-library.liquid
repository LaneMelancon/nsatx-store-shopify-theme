        </div>

        <div class="cl-item">
          <p class="cl-label">.field — email</p>
          <div class="field">
            <input class="field__input" type="email" id="cl-email" name="cl-email" placeholder="name@example.com" autocomplete="email">
            <label class="field__label" for="cl-email">Email Address</label>
          </div>
        </div>

        <div class="cl-item">
          <p class="cl-label">.field — textarea</p>
          <div class="field">
            <textarea class="field__input" id="cl-textarea" name="cl-textarea" rows="4" placeholder="Enter your message..."></textarea>
            <label class="field__label" for="cl-textarea">Message</label>
          </div>
        </div>

      </div>

      <div style="display: flex; flex-direction: column; gap: var(--gap-xl);">

        <div class="cl-item">
          <p class="cl-label">.checkbox</p>
          <div style="display: flex; flex-direction: column; gap: var(--gap-xs);">
            <div class="checkbox">
              <input type="checkbox" class="checkbox__input" id="cl-cb-1" name="cl-cb" value="1">
              <label class="checkbox__label" for="cl-cb-1">
                <svg class="icon-checkmark" viewBox="0 0 16 16" aria-hidden="true"><path d="M2 8 L6 12 L14 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span class="checkbox__label-text">Unchecked option</span>
              </label>
            </div>
            <div class="checkbox">
              <input type="checkbox" class="checkbox__input" id="cl-cb-2" name="cl-cb" value="2" checked>
              <label class="checkbox__label" for="cl-cb-2">
                <svg class="icon-checkmark" viewBox="0 0 16 16" aria-hidden="true"><path d="M2 8 L6 12 L14 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span class="checkbox__label-text">Checked option</span>
              </label>
            </div>
            <div class="checkbox checkbox--disabled">
              <input type="checkbox" class="checkbox__input" id="cl-cb-3" name="cl-cb" value="3" disabled>
              <label class="checkbox__label" for="cl-cb-3">
                <svg class="icon-checkmark" viewBox="0 0 16 16" aria-hidden="true"><path d="M2 8 L6 12 L14 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span class="checkbox__label-text">Disabled option</span>
              </label>
            </div>
          </div>
        </div>

        <div class="cl-item">
          <p class="cl-label">input[type="radio"]</p>
          <div style="display: flex; flex-direction: column; gap: var(--gap-sm);">
            <label style="display: flex; align-items: center; gap: var(--gap-sm); cursor: pointer; font-family: var(--font-body--family); font-size: var(--font-size--md);">
              <input type="radio" name="cl-radio" value="a"> Option One
            </label>
            <label style="display: flex; align-items: center; gap: var(--gap-sm); cursor: pointer; font-family: var(--font-body--family); font-size: var(--font-size--md);">
              <input type="radio" name="cl-radio" value="b" checked> Option Two (selected)
            </label>
            <label style="display: flex; align-items: center; gap: var(--gap-sm); cursor: pointer; font-family: var(--font-body--family); font-size: var(--font-size--md); opacity: var(--opacity-50);">
              <input type="radio" name="cl-radio" value="c" disabled> Disabled Option
            </label>
          </div>
        </div>

      </div>
    </div>
  </section>


